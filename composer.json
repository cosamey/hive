{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "cosamey/hive",
    "description": "Playful, opinionated starter kit for Laravel packages.",
    "keywords": ["laravel"],
    "license": "MIT",
    "authors": [
        {
            "name": "Chris Teyerl",
            "email": "chris.teyerl@cosamey.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.6"
    },
    "autoload": {
        "psr-4": {
            "Mey\\Hive\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mey\\Hive\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "vendor/bin/testbench package:discover --ansi"
        ],
        "analyse": "phpstan analyse --ansi",
        "check": [
            "@analyse",
            "@format:check",
            "@test"
        ],
        "format": "pint",
        "format:check": "pint --test",
        "test": "pest --ci"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mey\\Hive\\HiveServiceProvider"
            ],
            "aliases": {
                "Hive": "Mey\\Hive\\Facades\\Hive"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
